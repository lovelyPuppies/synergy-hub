{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb-dap",
      "request": "launch",
      "name": "Launch",
      "program": "${workspaceRoot}/build/x64-linux-gnu/fmt_example",
      "args": [],
      "env": [],
      "cwd": "${workspaceRoot}"
    },
    {
      "name": "Debug AArch64 (QEMU)",
      "type": "lldb-dap",
      "request": "attach",
      "program": "${workspaceRoot}/build/aarch64-linux-gnu/fmt_example",
      "gdb-remote-port": 1234,
      "gdb-remote-hostname": "localhost",
      // "cwd": "${workspaceRoot}",
      // "stopOnEntry": true,
      "initCommands": [
        "target create ${workspaceRoot}/build/aarch64-linux-gnu/fmt_example",
        "target remote localhost:1234",
        "b main",
        "c"
      ]
    }
  ]
}
