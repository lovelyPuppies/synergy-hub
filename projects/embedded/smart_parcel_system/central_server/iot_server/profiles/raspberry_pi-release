# https://docs.conan.io/2/tutorial/consuming_packages/cross_building_with_conan.html
[settings]
arch=armv8
os=Linux
build_type=Debug
compiler=clang
compiler.cstd=23
compiler.cppstd=23
compiler.version=19
compiler.libcxx=libc++


[buildenv]
CC=clang
CXX=clang++
CFLAGS=--target=aarch64-linux-gnu
CXXFLAGS=--target=aarch64-linux-gnu
LDFLAGS=--target=aarch64-linux-gnu -fuse-ld=lld


