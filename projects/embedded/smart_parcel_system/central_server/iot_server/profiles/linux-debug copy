[settings]
arch=x86_64
os=Linux
build_type=Debug
compiler=clang
compiler.cppstd=23
compiler.libcxx=libc++
compiler.version=19


[buildenv]
PATH=+(path)/home/linuxbrew/.linuxbrew/bin/:/home/linuxbrew/.linuxbrew/opt/llvm/bin

LD_LIBRARY_PATH=+(path)/home/linuxbrew/.linuxbrew/lib:/home/linuxbrew/.linuxbrew/lib/
LDFLAGS="-L/home/linuxbrew/.linuxbrew/Cellar/llvm/19.1.7/lib -lc++ -lc++abi"

CC=/home/linuxbrew/.linuxbrew/bin/clang
CXX=/home/linuxbrew/.linuxbrew/bin/clang++
CFLAGS="-fuse-ld=lld"
CXXFLAGS="-fuse-ld=lld"

