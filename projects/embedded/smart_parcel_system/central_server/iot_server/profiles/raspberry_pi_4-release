# https://docs.conan.io/2/tutorial/consuming_packages/cross_building_with_conan.html
[settings]
arch=armv8
os=Linux
build_type=Release
compiler=clang
compiler.cstd=23
compiler.cppstd=23
compiler.version=19
compiler.libcxx=libstdc++11

[buildenv]
CC=clang
CXX=clang++
LD=ld.lld
CFLAGS=--target=aarch64-linux-gnu -march=armv8-a -Wall -Wextra -I/usr/lib/gcc-cross/aarch64-linux-gnu/12/include -I/usr/aarch64-linux-gnu/include --gcc-toolchain=/usr/aarch64-linux-gnu
CXXFLAGS=--target=aarch64-linux-gnu -march=armv8-a -Wall -Wextra -I/usr/lib/gcc-cross/aarch64-linux-gnu/12/include -I/usr/aarch64-linux-gnu/include --gcc-toolchain=/usr/aarch64-linux-gnu
LDFLAGS=--target=aarch64-linux-gnu -L/usr/aarch64-linux-gnu/lib -L/usr/lib/gcc-cross/aarch64-linux-gnu/12 --gcc-toolchain=/usr/aarch64-linux-gnu

# 타겟 툴체인 및 CPU 아키텍처 플래그
#CFLAGS=--target=aarch64-linux-gnu -march=armv8-a -Wall -Wextra -I/usr/aarch64-linux-gnu/include
#CXXFLAGS=--target=aarch64-linux-gnu -march=armv8-a -Wall -Wextra -I/usr/aarch64-linux-gnu/include
#LDFLAGS=--target=aarch64-linux-gnu -fuse-ld=lld -L/usr/aarch64-linux-gnu/lib -L/usr/lib/gcc-cross/aarch64-linux-gnu/12 -Wl,--rpath=/usr/lib/gcc-cross/aarch64-linux-gnu/12

# /usr/lib/gcc-cross/aarch64-linux-gnu/12
# https://www.reddit.com/r/raspberry_pi/comments/13aktpk/comment/jj7hz7y/?utm_source=share&utm_medium=web3x&utm_name=web3xcss&utm_term=1&utm_content=share_button
# https://stackoverflow.com/questions/76193625/how-do-i-run-a-c20-program-on-a-raspberry-pi-1b?noredirect=1&lq=1
[conf]
tools.cmake.cmaketoolchain:generator=Ninja



