{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run QEMU for AArch64",
      "type": "shell",
      "command": "qemu-aarch64 -g 1234 -L /usr/aarch64-linux-gnu build/debug-aarch64-linux-gnu-clang",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": {
        "owner": "qemu",
        "pattern": {
          // dummy regex
          "regexp": ".^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*"
        }
      },
      "isBackground": true,
      "hide": true
    }
  ]
}
